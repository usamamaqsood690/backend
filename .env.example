DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set these for PostgreSQL in non-local environments.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=budget_ai_app
DB_USER=budget_user
DB_PASSWORD=replace-with-a-secure-password
DB_HOST=localhost
DB_PORT=5432

API_PAGE_SIZE=20
